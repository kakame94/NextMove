# ============================================
# Next Move MVP — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_POOLER_HOST=aws-1-ca-central-1.pooler.supabase.com
SUPABASE_POOLER_PORT=5432
SUPABASE_PROJECT_REF=your-project-ref

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-key

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- n8n ---
N8N_HOST=https://your-n8n-instance.com
N8N_API_KEY=your-n8n-api-key

# --- Courtier default (for testing) ---
DEFAULT_COURTIER_PHONE=+1XXXXXXXXXX
DEFAULT_COURTIER_EMAIL=courtier@example.com
