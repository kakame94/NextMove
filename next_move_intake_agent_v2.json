    {
      "parameters": {
        "jsCode": "// Dedup: check if this messageSid was already processed\nconst sid = $input.first().json?.data?.messageSid;\nif (!sid) return []; // no sid = skip\n\n// Pass through - the Wait node debounce handles timing\n// This node ensures we only process unique message IDs\nconst seen = $getWorkflowStaticData('global');\nif (seen[sid]) {\n  return []; // Already processed, skip\n}\nseen[sid] = Date.now();\n\n// Cleanup old entries (keep last 100)\nconst keys = Object.keys(seen);\nif (keys.length > 100) {\n  const oldest = keys.slice(0, keys.length - 100);\n  oldest.forEach(k => delete seen[k]);\n}\n\nreturn [$input.first()];"
      },
