    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO prospects (\n  canal_source,\n  statut,\n  telephone,\n  courtier_id,\n  type_projet,\n  score_chaleur,\n  nom,\n  prenom,\n  langue_preferee,\n  created_at,\n  updated_at\n)\nVALUES (\n  'sms',\n  'qualifie',\n  '={{ $(\\'Wait for Text Response\\').item.json.data.from }}',\n  (SELECT id FROM courtiers LIMIT 1),\n  CASE\n    WHEN LOWER('={{ $(\\'Summarize Transcript\\').item.json.output.summary }}') LIKE '%vendeur%' THEN 'vente'\n    ELSE 'achat'\n  END,\n  70,\n  'Prospect',\n  'SMS',\n  'fr',\n  NOW(),\n  NOW()\n)\nON CONFLICT (telephone)\nDO UPDATE SET\n  statut = 'qualifie',\n  score_chaleur = 70,\n  updated_at = NOW()\nRETURNING id, telephone, statut, created_at;",
        "options": {}
